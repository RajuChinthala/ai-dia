# LLM configuration (copy to .env and set your real key)
# Switch between hosted provider and local model
USE_LOCAL_MODEL=false

# Use either LLM_API_KEY or OPENAI_API_KEY
LLM_API_KEY=your_llm_api_key_here
# OPENAI_API_KEY=your_openai_api_key_here

# LLM endpoint and model
LLM_API_BASE=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
LLM_TIMEOUT_SEC=45
LLM_RETRY_MAX=3
LLM_RETRY_BACKOFF_SEC=1.0
LLM_MAX_TOKENS=512

# Local Ollama (OpenAI-compatible endpoint) example:
# USE_LOCAL_MODEL=true
# LOCAL_LLM_API_BASE=http://localhost:11434
# LOCAL_LLM_MODEL=llama3.2:3b
# LLM_MAX_TOKENS=2048
# LOCAL_LLM_API_KEY=

# Optional source API defaults for agent pipeline
SOURCE_SALES_API_URL=builtin://sales?days=14&products=5&seed=42
SOURCE_WEATHER_API_URL=builtin://weather?city=OHIO&lat=40.1088&lon=-82.9742&days=4
SOURCE_SEASONAL_API_URL=builtin://social?days=14&seed=42

# BigCommerce integration (canonical model: product -> locations)
BIGCOMMERCE_STORE_HASH=your_store_hash
BIGCOMMERCE_ACCESS_TOKEN=your_access_token
BIGCOMMERCE_API_BASE=https://api.bigcommerce.com
